@page "/Simulation/{id:guid}"
@inject NavigationManager Navigation
@using NORCE.Drilling.Simulator4nDOF.WebApp
@inject ILogger<SimulationMain> logger
@inject ISnackbar Snackbar

<MudUnitAndReferenceChoiceTag HttpHost="@APIUtils.HostNameUnitConversion"
                              HttpBasePath="@APIUtils.HostBasePathUnitConversion"
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@UpdateUnitSystemName">

    <!-- Full-width container for simulation content -->
    @if (SimulationList == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (currentLightSimulation != null)
    {
        <MudPaper Class="pa-4">
            <MudGrid AlignItems="Center" GutterSize="16px">
                <!-- Buttons Row -->
                <MudItem xs="12">
                    <div style="display: flex; gap: 12px;">
                        <MudButton OnClick="@GetCurrentSimulationHeavy"
                                    IconColor="Color.Primary"
                                    Size="Size.Medium"
                                    Style="border-radius: 8px;"
                                    Variant="Variant.Filled"
                                    StartIcon="@Icons.Material.Filled.Refresh">
                            Get simulation results
                        </MudButton>

                        <MudButton OnClick="@CloseViewSimulationPanelOnClick"
                                    Color="Color.Error"
                                    Class="add-item-btn"
                                    StartIcon="@Icons.Material.Filled.ArrowBackIosNew">
                            Back
                        </MudButton>
                    </div>
                </MudItem>

                <!-- Simulation Details -->
                <MudItem xs="2">
                    <MudText Typo="Typo.body1"><b>Name:</b></MudText>
                    <MudText Typo="Typo.body1" Class="ml-0 mt-2">@currentLightSimulation.Name</MudText>
                </MudItem>

                <MudItem xs="3">
                    <MudText Typo="Typo.body1"><b>Description:</b></MudText>
                    <MudText Typo="Typo.body1" Class="ml-0 mt-2">@currentLightSimulation.Description</MudText>
                </MudItem>

                <MudItem xs="2">
                    <MudText Typo="Typo.body1"><b>ID:</b></MudText>
                    <MudText Typo="Typo.body1" Class="ml-0 mt-2">@currentLightSimulation.MetaInfo.ID</MudText>
                </MudItem>

                <MudItem xs="2">
                    <MudText Typo="Typo.body1"><b>Progress:</b></MudText>
                    <MudChip T="string" Color="@GetProgressColor(currentLightSimulation.Progress)" Class="ml-0">
                        @($"{currentLightSimulation.Progress:P2}")
                    </MudChip>
                </MudItem>

                <MudItem xs="3">
                    <MudText Typo="Typo.body1"><b>Termination State:</b></MudText>
                    <MudChip T="string" Color="@GetTerminationColor(currentLightSimulation.TerminationState)" Class="ml-0">
                        @GetTerminationStateLabel(currentLightSimulation.TerminationState)
                    </MudChip>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (results != null)
        {
            <SimulationResultsPanel @ref="resultsPanelRef" Results="@results" />
        }
    }
</MudUnitAndReferenceChoiceTag>

@code {
    [Parameter]
    public Guid  id { get; set; }

    private SimulationResultsPanel? resultsPanelRef;

    // Simulation related variables
    private List<SimulationLight> SimulationList = new();
    private List<SimulationLight> selectedSimulationList = new();
    private SimulationLight? currentLightSimulation;
    private Simulation? currentSimulation;
    private List<object?>? inputDataList = new(); // container used to pass input data to the SimulationEdit razor component without specifying content types (required by µservice Template)
    private Results results;
    private Simulation newSimulation = new();

    // private List<ToBeRemoved>? toBeRemovedList;

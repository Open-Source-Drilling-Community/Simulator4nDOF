@using OSDC.UnitConversion.Conversion
@using Plotly.Blazor.LayoutLib
@using Plotly.Blazor.Traces.ScatterLib
@inherits LayoutComponentBase

@*<MudText Class="mt-4 mb-4" Typo="Typo.h6">Simulation results</MudText>*@
<MudLayout>
    @*
    <MudPaper Elevation="2" Class="pa-2 mb-2" Outlined="true">
        <div Class="d-flex flex-grow-1 align-center pa-0 ma-0">
            <MudGrid Class="pa-0 ma-0 gap-3 " Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
                <MudItem Class="pa-0 ma-0">
                    <MudTextField Label="Cumulative SSI [-]"
                                  @bind-Value=@Results.AvgCumulativeSSI
                                  Variant=Variant.Filled
                                  Style="width:150px"
                                  Adornment="Adornment.Start"
                                  AdornmentColor="Color.Warning"
                                  Margin="MudBlazor.Margin.Dense"
                                  Format="F3" />
                </MudItem>
            </MudGrid>
        </div>
    </MudPaper>
    *@

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" ActivePanelIndex="@activeTab" ActivePanelIndexChanged="OnTabChanged">

        <MudTabPanel Text="Time graphs">
            <MudGrid>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_depthLayout" @bind-Data="_depthTraces" @ref="_depthChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_rpmLayout" @bind-Data="_rpmTraces" @ref="_rpmChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_torqueLayout" @bind-Data="_torqueTraces" @ref="_torqueChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_velocityLayout" @bind-Data="_velocityTraces" @ref="_velocityChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_wobLayout" @bind-Data="_wobTraces" @ref="_wobChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_ssiLayout" @bind-Data="_ssiTraces" @ref="_ssiChart" />
                </MudItem>

            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Depth graphs ">
            <MudGrid Class="pa-0 ma-0" Style="flex-wrap: nowrap; overflow-x: auto;"  Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_angularVelocityLayout" @bind-Data="_angularVelocityTraces" @ref="_angularVelocityChart" />
                </MudItem>
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_axialVelocityLayout" @bind-Data="_axialVelocityTraces" @ref="_axialVelocityChart" />
                </MudItem>
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_lateralDispLayout" @bind-Data="_lateralDispTraces" @ref="_lateralDispChart" />
                </MudItem>
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_lateralDispALayout" @bind-Data="_lateralDispATraces" @ref="_lateralDispAChart" />
                </MudItem>
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_bendingMomentLayout" @bind-Data="_bendingMomentTraces" @ref="_bendingMomentChart" />
                </MudItem>
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_sideForceLayout" @bind-Data="_sideForceTraces" @ref="_sideForceChart" />
                </MudItem>
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_torqueDLayout" @bind-Data="_torqueDTraces" @ref="_torqueDChart" />
                </MudItem>
                <MudItem Style="flex: 0 0 12%;">
                    <PlotlyChart style="height: 80vh; min-height: 350px; width: 100%" @bind-Config="_config" @bind-Layout="_tensionLayout" @bind-Data="_tensionTraces" @ref="_tensionChart" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Sensor measurements">
            <MudGrid>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_sensorVelocityALayout" @bind-Data="_sensorVelocityATraces" @ref="_sensorVelocityAChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_sensorVelocityLayout" @bind-Data="_sensorVelocityTraces" @ref="_sensorVelocityChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_sensorRadialAccLayout" @bind-Data="_sensorRadialAccTraces" @ref="_sensorRadialAccChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_sensorTangentialAccLayout" @bind-Data="_sensorTangentialAccTraces" @ref="_sensorTangentialAccChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_sensorAxialAccLayout" @bind-Data="_sensorAxialAccTraces" @ref="_sensorAxialAccChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_sensorBendingMomentLayout" @bind-Data="_sensorBendingMomentTraces" @ref="_sensorBendingMomentChart" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</MudLayout>


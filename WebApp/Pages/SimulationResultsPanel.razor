    private Layout CreateLayout(string xTitle, string yTitle, bool reversedYAxis = true, double? minAllowed = null, IList<object> range = null, Plotly.Blazor.LayoutLib.Margin margin = null) =>
    new Layout
        {
            Margin = margin ?? this.margin, // Allows different margin settings
            XAxis = new[] { new XAxis { Side = Plotly.Blazor.LayoutLib.XAxisLib.SideEnum.Bottom,
                                    Title = new Plotly.Blazor.LayoutLib.XAxisLib.Title { Text = xTitle } } },
            YAxis = new[] { new YAxis { Title = new Plotly.Blazor.LayoutLib.YAxisLib.Title { Text = yTitle },
                                    AutoRange = reversedYAxis ? Plotly.Blazor.LayoutLib.YAxisLib.AutoRangeEnum.Reversed : null,
                                    MinAllowed = minAllowed,
                                    Range = range } },
            Annotations = new List<Annotation>(),
            Colorway = new List<object> { "#b7127c", "#07b2b2", "#0073ac", "#f88707" }
        };


    public async Task Refresh()
    {
        if (Results != null)
        {
            CreateLayouts();
            _ = Run();
            await AfterSetValueAsync();
        }
    }

    private async Task OnTabChanged(int newIndex)
    {
        activeTab = newIndex;

        await Refresh();

    }


    private Layout CreateLayout(string xTitle, string yTitle, bool reversedYAxis = true, double? minAllowed = null, IList<object> range = null, Plotly.Blazor.LayoutLib.Margin margin = null) =>
    new Layout
    {
        Margin = margin ?? this.margin, // Allows different margin settings
        XAxis = new[] { new XAxis { Side = Plotly.Blazor.LayoutLib.XAxisLib.SideEnum.Bottom,
                                    Title = new Plotly.Blazor.LayoutLib.XAxisLib.Title { Text = xTitle } } },
        YAxis = new[] { new YAxis { Title = new Plotly.Blazor.LayoutLib.YAxisLib.Title { Text = yTitle },
                                    AutoRange = reversedYAxis ? Plotly.Blazor.LayoutLib.YAxisLib.AutoRangeEnum.Reversed : null,
                                    MinAllowed = minAllowed,
                                    Range = range } },
        Annotations = new List<Annotation>(),
        Colorway = new List<object> { "#b7127c", "#07b2b2", "#0073ac", "#f88707" }
    };

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        _config = new Config
        {
            ShowLink = false,
            Responsive = true,
            DisplayLogo = false
        };

        _rpmTraces.Add(_bitRpmTrace);
        _rpmTraces.Add(_surfaceRpmTrace);
        _depthTraces.Add(_bitDepthTrace);
        _depthTraces.Add(_holeDepthTrace);
        _wobTraces.Add(_wobTrace);
        _ssiTraces.Add(_ssiTrace);
        _torqueTraces.Add(_surfaceTorqueTrace);
        _torqueTraces.Add(_bitTorqueTrace);
        _velocityTraces.Add(_surfaceAxialVelocityTrace);
        _velocityTraces.Add(_bitAxialVelocityTrace);
        _sideForceTraces.Add(_sideForceTrace);
        _sideForceTraces.Add(_sideForceTraceSoftstring);
        _angularVelocityTraces.Add(_pipeAngularVelocityTrace);
        _angularVelocityTraces.Add(_sleevesAngularVelocityTrace);
        _axialVelocityTraces.Add(_axialVelocityTrace);
        _lateralDispTraces.Add(_lateralDispTrace);
        _lateralDispTraces.Add(_radialClearanceLeftTrace);
        _lateralDispTraces.Add(_radialClearanceRightTrace);
        _lateralDispATraces.Add(_lateralDispATrace);
        _bendingMomentTraces.Add(_bendingMomentTrace);
        _torqueDTraces.Add(_torqueDTrace);
        _tensionTraces.Add(_tensionTrace);
        _sensorVelocityATraces.Add(_sensorAngularVelocityTrace);
        _sensorVelocityATraces.Add(_sensorWhirlVelocityTrace);
        _sensorVelocityTraces.Add(_sensorAxialVelocityTrace);
        _sensorVelocityTraces.Add(_sensorRadialVelocityTrace);
        _sensorRadialAccTraces.Add(_sensorRadialAccTrace);
        _sensorTangentialAccTraces.Add(_sensorTangentialAccTrace);
        _sensorAxialAccTraces.Add(_sensorAxialAccTrace);
        _sensorBendingMomentTraces.Add(_sensorBendingMomentXTrace);
        _sensorBendingMomentTraces.Add(_sensorBendingMomentYTrace);


        CreateLayouts();

        base.OnInitialized();

    }

    private void CreateLayouts()
    {
        // Depth-based layouts with marginDepth
        _sideForceLayout = CreateLayout("Side force [" + Parent.GetUnitLabel("Force") + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);
        _angularVelocityLayout = CreateLayout("Angular velocity [" + Parent.GetUnitLabel(OSDC.UnitConversion.Conversion.DrillingEngineering.PhysicalQuantity.QuantityEnum.AngularVelocityDrilling) + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);
        _axialVelocityLayout = CreateLayout("Axial velocity [" + Parent.GetUnitLabel("RateOfPenetrationDrilling") + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);
        _lateralDispLayout = CreateLayout("Lateral displ. [" + Parent.GetUnitLabel("DepthDrilling") + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);
        _lateralDispALayout = CreateLayout("Lateral displ. [" + Parent.GetUnitLabel("DepthDrilling") + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);
        _bendingMomentLayout = CreateLayout("Bending moment [" + Parent.GetUnitLabel("TorqueDrilling") + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);
        _tensionLayout = CreateLayout("Tension [" + Parent.GetUnitLabel("Force") + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);
        _torqueDLayout = CreateLayout("Torque [" + Parent.GetUnitLabel("TorqueDrilling") + "]", "Depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", true, 0.0001, null, marginDepth);

        // Time-based layouts with default margin
        _rpmLayout = CreateLayout("Time", "RPM [" + Parent.GetUnitLabel(OSDC.UnitConversion.Conversion.DrillingEngineering.PhysicalQuantity.QuantityEnum.AngularVelocityDrilling) + "]", false);
        _depthLayout = CreateLayout("Time", "Measured depth [" + Parent.GetUnitLabel("DepthDrilling") + "]", false);
        _wobLayout = CreateLayout("Time", "WOB [" + Parent.GetUnitLabel("MassDrilling") + "]", false);
        _ssiLayout = CreateLayout("Time", "SSI [-]", false);
        _velocityLayout = CreateLayout("Time", "Axial velocity [" + Parent.GetUnitLabel("RateOfPenetrationDrilling") + "]", false);
        _torqueLayout = CreateLayout("Time", "Torque [" + Parent.GetUnitLabel("TorqueDrilling") + "]", false);

        _sensorVelocityALayout = CreateLayout("Time", "Velocities [" + Parent.GetUnitLabel(OSDC.UnitConversion.Conversion.DrillingEngineering.PhysicalQuantity.QuantityEnum.AngularVelocityDrilling) + "]", false);
        _sensorVelocityLayout = CreateLayout("Time", "Velocities [" + Parent.GetUnitLabel("RateOfPenetrationDrilling") + "]", false);
        _sensorRadialAccLayout = CreateLayout("Time", "Radial acc. [" + Parent.GetUnitLabel("AccelerationDrilling") + "]", false);
        _sensorTangentialAccLayout = CreateLayout("Time", "Tangential acc. [" + Parent.GetUnitLabel("AccelerationDrilling") + "]", false);
        _sensorAxialAccLayout = CreateLayout("Time", "Axial acc. [" + Parent.GetUnitLabel("AccelerationDrilling") + "]", false);
        _sensorBendingMomentLayout = CreateLayout("Time", "Bending moment [" + Parent.GetUnitLabel("TorqueDrilling") + "]", false);

    }


    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = Run();
        }
        return base.OnAfterRenderAsync(firstRender);
    }


    private async Task AfterSetValueAsync()
    {
        // fake async behaviour
        await Task.Yield();
    }

    private Task Run()
    {
        //var test = Parent.UnitSystemName;
       // var testval = Parent.FromSI(1000, "ForceDrilling");
        //var label = Parent.GetUnitLabel("ForceDrilling");
        return Task.Run(async () =>
        {
            if (Results.Time.Count > 0)
            {
                try
                {
                    var x = new List<object>();
                    var BitRPM = new List<object>();
                    var SurfaceRPM = new List<object>();
                    var BitDepth = new List<object>();
                    var HoleDepth = new List<object>();
                    var SurfaceTorque = new List<object>();
                    var BitTorque = new List<object>();
                    var WOB = new List<object>();
                    var SSI = new List<object>();
                    var TopOfStringAxialVelocity = new List<object>();
                    var BitAxialVelocity = new List<object>();
                    var y10 = new List<object>();

                    List<object> SensorAngularVelocity = new List<object>();
                    List<object> SensorWhirlVelocity = new List<object>();
                    List<object> SensorAxialVelocity = new List<object>();
                    List<object> SensorRadialVelocity = new List<object>();
                    List<object> SensorRadialAcc = new List<object>();
                    List<object> SensorTangentialAcc = new List<object>();
                    List<object> SensorAxialAcc = new List<object>();
                    List<object> SensorBendingMomentX = new List<object>();
                    List<object> SensorBendingMomentY = new List<object>();

                    int startIndex = 0;


                    var test = Parent.UnitSystemName;
                    Parent.HttpHost = "https://dev.digiwells.no/";
                    var testval = Parent.FromSI(1000, OSDC.UnitConversion.Conversion.DrillingEngineering.PhysicalQuantity.QuantityEnum.AngularVelocityDrilling);
                    var label = Parent.GetUnitLabel(OSDC.UnitConversion.Conversion.DrillingEngineering.PhysicalQuantity.QuantityEnum.AngularVelocityDrilling);
                    var testval2 = Parent.FromSI(1000, "Frequency");
                    var label2 = Parent.GetUnitLabel("Frequency");
                    var testval3 = Parent.FromSI(1000, "MassDrilling");
                    var label3 = Parent.GetUnitLabel("WeightOnBitDrilling");

                    if (activeTab == 0)
                    {
                        for (int i = startIndex; i < Results.Time.Count; i++)
                        {
                            x.Add(Results.Time.ElementAt(i));
                            BitRPM.Add(Parent.FromSI(Results.BitRPM.ElementAt(i), OSDC.UnitConversion.Conversion.DrillingEngineering.PhysicalQuantity.QuantityEnum.AngularVelocityDrilling));
                            SurfaceRPM.Add(Parent.FromSI(Results.SurfaceRPM.ElementAt(i), OSDC.UnitConversion.Conversion.DrillingEngineering.PhysicalQuantity.QuantityEnum.AngularVelocityDrilling));
                            BitDepth.Add(Parent.FromSI(Results.BitDepth.ElementAt(i), "DepthDrilling"));

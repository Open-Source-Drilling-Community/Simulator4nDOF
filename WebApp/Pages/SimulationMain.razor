        double extraVerticalForceAbnormal = 50000; //100000.0;
        double extraVerticalForceNormal = 0.0;
        double stribeckCriticalVelocityNormal = 0.15; // 0.2
        double stribeckCriticalVelocityAbnormal = 0.40; // yes 0.40 // no 0.45 // no 0.43 // no 0.42 // no 0.41
        double differenceStaticKineticFrictionNormal = 0.1; // 0.1
        double differenceStaticKineticFrictionAbnormal = 0.13;
        newSimulation = new()
        {
            MetaInfo = metaInfo,
            Name = DataUtils.DEFAULT_NAME_Simulation,
            Description = DataUtils.DEFAULT_DESCR_Simulation,
            CreationDate = creationDate,
            LastModificationDate = creationDate,
            Config = new NORCE.Drilling.Simulator4nDOF.ModelShared.Config()
            {
                VirtualSensorPositionFromBit = 110,
                LoggingIntervalScalarValues = 0.1,
                LoggingIntervalProfiles = 0.1,
                CoulombStaticFriction = 0.25,
                CoulombKineticFriction = 0.18,
                UseHeave = false,
                HeaveAmplitude = 0.00,
                HeavePeriod = 11,
                TopDriveController = 1,
                // ZTorque filter and tuning defaults
                VFDFilterTimeconstantZTorque = 0.005,
                EncoderTimeConstantZTorque = 0.002,
                AccelerationFilterTimeConstantZTorque = 0.005,
                TorqueHighPassFilterTimeConstantZTorque = 20,
                TorqueLowPassFilterTimeConstantZTorque = 0.005,
                AdditionalTuningFactorZTorque = 0.25,
                InertiaCorrectionFactorZTorque = 1.00,
                LengthBetweenLumpedElements = 10.0,
                TopDriveStartupTime = 0,
                // Top drive controller gains
                KpSoftTorqueSpeed = 4,
                KiSoftTorqueSpeed = 0,
                TuningFrequenceySoftTorqueSpeed = 0.2,
                KpStiffAndZTorque = 50,
                KiStiffAndZTorque = 5,
            },
            ContextualData = new ContextualData()
            {
                TrajectoryFile = "C:\\HarbourEnergy\\Trajectory.txt",
                DrillStringSource = DrillStringSourceType.DrillStringMS,
                AnnulusPressureFile = "C:\\HarbourEnergy\\AnnulusHydraulicProfiles.txt",
                DrillstringPressureFile = "C:\\HarbourEnergy\\DrillstringHydraulicProfiles.txt",
                DrillstringFile = "C:\\HarbourEnergy\\Drillstring.csv",
                DrillStringID = new Guid("c8deb96c-dc6a-403c-9502-1029fddf8917"), //new Guid("fee4592a-8ed9-4937-86b5-53489c55957e"),
                DrillStringOpenLabID = new Guid("c5cf7441-7e9b-4c18-84c7-e0707f13ee1a"),
                BoreHoleSizeList = new List<BoreHoleSize>() { new BoreHoleSize() { Depth = 336.0, ID = 19.188 * 0.0254 }, new BoreHoleSize() { Depth = 4160.0, ID = 8.553 * 0.0254 }, new BoreHoleSize() { Depth = 4170.0, ID = 12.25 * 0.0254 } },
                BitRadius = 8.5 * 0.0254 / 2.0,
                FluidDensity = 1260,
            },
            InitialValues = new InitialValues()
            {
                BitDepth = 4280,
                HoleDepth = 6170,
                TopOfStringPosition = 5
            },
            SetPointsList = new List<SetPoints>
            {
                    new SetPoints
                    {
                        TimeDuration = 30,
                        SurfaceRPM = 2.0792184547429953,
                        TopOfStringVelocity = 0
                    },
            },
        };
    }

    private async Task AddSimulation()
    {
        try
        {
            MetaInfo metaInfo = new() { ID = Guid.NewGuid(), HttpHostName = APIUtils.HostNameSimulator4nDOF, HttpHostBasePath = APIUtils.HostBasePathSimulator4nDOF, HttpEndPoint = "Simulations/" };
            DateTimeOffset creationDate = DateTimeOffset.UtcNow;
            newSimulation.MetaInfo = metaInfo;
            newSimulation.CreationDate = creationDate;
            newSimulation.LastModificationDate = creationDate;
            await APIUtils.ClientSimulator4nDOF.PostSimulationAsync(this.newSimulation);
            logger.LogInformation("Simulation posted successfully");
            Snackbar.Add("Simulation posted successfully", Severity.Success);
            await OnInitializedAsync();
            autoUpdate = true;
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to add a new Simulation");
            Snackbar.Add("Impossible to add a new Simulation", Severity.Warning);
        }
    }

    private async Task ViewSimulation(Guid id)
    {
        autoUpdate = false;

        try
        {
            Navigation.NavigateTo($"/Simulator4nDOF/webapp/Simulation/{id}");
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load Simulation to be edited");
        }
    }

    private async Task RowClicked(DataGridRowClickEventArgs<SimulationLight> args)
    {
        var id = args.Item.MetaInfo.ID;
        autoUpdate = false;

        try
        {
            Navigation.NavigateTo($"/Simulator4nDOF/webapp/Simulation/{id}");
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load Simulation to be edited");
        }
    }

    private async Task DeleteSimulation(Guid id)
    {
        try
        {
            await APIUtils.ClientSimulator4nDOF.DeleteSimulationByIdAsync(id);
            await OnInitializedAsync();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete Simulation");
        }
    }
}

@page "/Simulation"
@using NORCE.Drilling.Simulator4nDOF.WebApp
@inject ILogger<SimulationMain> logger
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudUnitAndReferenceChoiceTag HttpHost=@APIUtils.HostNameUnitConversion
                              HttpBasePath=@APIUtils.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName">
    @if (SimulationList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div hidden="@isHiddenMainPanel">

            <MudPaper Class="pa-4">
                <MudButton OnClick="@OnExpandCollapseClickAddPanel" IconColor="Color.Success" StartIcon="@Icons.Material.Filled.Add">New simulation </MudButton>
                <br>
                <MudDataGrid T="SimulationLight" MultiSelection="false" Items="@SimulationList" ReadOnly="true" ColumnResizeMode="ResizeMode.Column" Elevation="0" RowClick="@RowClicked">
                    <Columns>
                        <PropertyColumn Property="x => x.Name" Title="Name" CellStyle="width: 10%;" Sortable="true" Editable="false" />
                        <PropertyColumn Property="x => x.Description" Title="Description" CellStyle="width: 20%;" Sortable="true" Editable="false" />
                        <PropertyColumn Property="x => x.MetaInfo.ID.ToString()" Title="Id" CellStyle="width: 30%;" Sortable="true" Editable="false" />
                        <PropertyColumn Property="x => x.CreationDate.ToString()" Title="Creation date" CellStyle="width: 15%;" Sortable="true" Editable="false" />

                        <TemplateColumn Title="Progress" CellStyle="width: 10%;">
                            <CellTemplate Context="context">
                                @($"{context.Item.Progress:P2}")
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Termination State" CellStyle="width: 10%;">
                            <CellTemplate Context="context">
                                <MudChip Color="@GetTerminationColor(context.Item.TerminationState)">
                                    @GetTerminationStateLabel(context.Item.TerminationState)
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Actions" CellStyle="width: 5%;">
                            <CellTemplate Context="context">
                                <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="() => DeleteSimulation(context.Item.MetaInfo.ID)" />
                                <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                               Size="Size.Small"
                                               Color="Color.Success"
                                               OnClick="() => ViewSimulation(context.Item.MetaInfo.ID)" />
                            </CellTemplate>

                        </TemplateColumn>
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager T="SimulationLight" />
                    </PagerContent>
                </MudDataGrid>

                <MudButton OnClick="@OnExpandCollapseClickAddPanel" IconColor="Color.Success" StartIcon="@Icons.Material.Filled.Add">New simulation </MudButton>
                <br>
            </MudPaper>
        </div>
        <div hidden="@isHiddenEditSimulationPanel">
            <MudPaper Class="pa-4">
                <MudCollapse Expanded=true>
                    <MudText Typo="Typo.h5">Edit new simulation </MudText>
                    <MudToolBar>
                        <MudButton OnClick="@AddSimulation" IconColor="Color.Success" Class="add-item-btn" StartIcon="@Icons.Material.Filled.Check">Add simulation</MudButton>
                        <MudButton OnClick="@CloseViewSimulationPanelOnClick" Color="Color.Error" Class="add-item-btn" StartIcon="@Icons.Material.Filled.ArrowBackIosNew">Back</MudButton>
                    </MudToolBar>
                    <MudPaper Class="pa-4">

                        <MudGrid RowSpacing="0" Style="margin-top:-0px;">
                            <MudItem xs="2">
                                <MudTextField @bind-Value=newSimulation.Name Label="Name" Variant="Variant.Text"></MudTextField>
                            </MudItem>
                            <MudItem xs="2">
                                <MudTextField @bind-Value=newSimulation.Description Label="Description" Variant="Variant.Text"></MudTextField>
                            </MudItem>
                        </MudGrid>

                        @if (newSimulation?.InitialValues != null)
                        {
                            <br>
                            <MudText Typo="Typo.h6" Style="margin-bottom:-12px; margin-top: 12px;" MudText>Initial values </MudText>
                            <SimulationInitialValues Simulation="@newSimulation" />
                        }
                        @if (newSimulation?.Config != null)
                        {
                            <br>
                            <MudText Typo="Typo.h6" Style="margin-bottom:-12px; margin-top: 12px;">Configuration </MudText>
                            <SimulationConfiguration Simulation="@newSimulation" />
                        }

                        @if (newSimulation?.ContextualData != null)
                        {
                            <br>
                            <MudText Typo="Typo.h6" Style="margin-bottom:-12px; margin-top: 12px;">Contextual data </MudText>
                            <SimulationContextualData Simulation="@newSimulation" />

                        }
                        @if (newSimulation?.SetPointsList != null)
                        {
                            <br>
                            <MudText Typo="Typo.h6">Set points</MudText>

                            <SetPointsEditor NewSimulation="@newSimulation" />

                            <MudButton OnClick="@AddSetPoint" IconColor="Color.Success" StartIcon="@Icons.Material.Filled.Add">Add set points </MudButton>
                        }

                    </MudPaper>
                </MudCollapse>
            </MudPaper>
        </div>
    }
</MudUnitAndReferenceChoiceTag>
@code {

    // Simulation related variables
    private List<SimulationLight> SimulationList = new();
    private List<SimulationLight> selectedSimulationList = new();
    private SimulationLight? currentLightSimulation;
    private Simulation? currentSimulation;
    private List<object?>? inputDataList = new(); // container used to pass input data to the SimulationEdit razor component without specifying content types (required by µservice Template)
    private Simulation newSimulation = new();
    public bool isHiddenMainPanel;
    public bool isHiddenEditSimulationPanel;
    public bool autoUpdate;

    private Color GetProgressColor(double? progress)
    {
        if (progress == null) return Color.Default;

        return progress switch
        {
            <= 0.25 => Color.Error,
            <= 0.75 => Color.Warning,
            < 1.0 => Color.Info,
            _ => Color.Success
        };
    }

    private string GetTerminationStateLabel(int state)
    {
        return state switch
        {
            0 => "Running",
            1 => "Completed",
            2 => "Failed",
            3 => "Cancelled",
            _ => "Unknown"
        };
    }
    private Color GetTerminationColor(int state)
    {
        return state switch
        {
            0 => Color.Info,
            1 => Color.Success,
            2 => Color.Error,
            3 => Color.Warning,
            _ => Color.Default
        };
    }

    private async Task DeleteSetPoints(SetPoints item)
    {
        if (item != null)
        {
            newSimulation.SetPointsList.Remove(item);
        }

        // Optional UI refresh
        await InvokeAsync(StateHasChanged);
    }

    private void UploadFile(InputFileChangeEventArgs e, Action<string> setFileName)
    {
        var file = e.File;
        if (file != null)
        {
            setFileName(file.Name);
        }
    }

    private void CloseViewSimulationPanelOnClick()
    {
        isHiddenEditSimulationPanel = true;
        isHiddenMainPanel = false;
        autoUpdate = true;
    }

    private void OnExpandCollapseClickAddPanel()
    {
        NewDefaultSimulation();
        isHiddenEditSimulationPanel = false;
        isHiddenMainPanel = true;
        autoUpdate = false;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isHiddenMainPanel = false;
            isHiddenEditSimulationPanel = true;
            currentLightSimulation = null;

            // Starting all loading tasks asynchronously
            logger.LogInformation("Trying to load list of ToBeRemoved from client: " + APIUtils.HostNameSimulator4nDOF);
            logger.LogInformation("Trying to load list of Simulation from client: " + APIUtils.HostNameSimulator4nDOF);
            var SimulationTask = APIUtils.ClientSimulator4nDOF.GetAllSimulationLightAsync();

            List<Task> loadingTaskList = new List<Task> { SimulationTask };

            // Awaiting tasks and retrieve results as they become available
            while (loadingTaskList.Count > 0)
            {
                Task finishedTask = await Task.WhenAny(loadingTaskList);
                if (finishedTask == SimulationTask)
                {
                    try
                    {
                        SimulationList = (List<SimulationLight>)await SimulationTask;

                        if (SimulationList != null)
                        {
                            SimulationList.Sort((t1, t2) => t1.Name.CompareTo(t2.Name));
                        }
                        else
                        {
                            logger.LogWarning("Returned list of Simulation were null on initialization");
                            Snackbar.Add("Returned list of Simulation were null on initialization", Severity.Warning);
                        }

                        while (SimulationList != null && SimulationList.Any(s => s.TerminationState < 1))
                        {
                            SimulationTask = APIUtils.ClientSimulator4nDOF.GetAllSimulationLightAsync();
                            SimulationList = (List<SimulationLight>)await SimulationTask;

                            if (SimulationList != null)
                            {
                                autoUpdate = true;
                                await InvokeAsync(() => { StateHasChanged(); });
                            }
                            else
                            {
                                logger.LogWarning("Impossible to load Simulations");
                                Snackbar.Add("Impossible to load Simulations", Severity.Warning);
                            }
                            await Task.Delay(1000);
                            if (!autoUpdate)
                            {
                                break;
                            }
                        }
                    }
                    catch (ApiException ex)
                    {
                        logger.LogError(ex, "Impossible to load Simulation from client");
                    }
                }

                loadingTaskList.Remove(finishedTask);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem Simulation initialization");
        }
        await InvokeAsync(() => { StateHasChanged(); });
    }

    private void AddSetPoint()
    {
        newSimulation.SetPointsList.Add(new SetPoints() { TimeDuration = 1, SurfaceRPM = 0, TopOfStringVelocity = 0 });
    }


        {
            Primary = new MudBlazor.Utilities.MudColor("#2E888D"), // DigiWells green-blue
            Secondary = new MudBlazor.Utilities.MudColor("#222742"), // DigiWells dark-blue
            AppbarBackground = "#DAD7E0",
            Background = "#DAD7E0",

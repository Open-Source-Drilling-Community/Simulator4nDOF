    public async Task Refresh()
    {
        if (Results != null)
        {
            if (endIndex == 0.0)
            {
                endIndex = maxIndex;
            }
            CreateLayouts();
            _ = Run();
            await AfterSetValueAsync();
        }
    }

    private async Task OnTabChanged(int newIndex)
    {
        activeTab = newIndex;
        await Refresh();
    }

    private async Task OnProfileIndexChanged(double value)
    {
        selectedProfileIndex = (int)value;

        await Refresh();
    }

    private async Task OnProfileStartDepthChanged(double value)
    {
        selectedStartDepthInUserUnit = value;
        minimumEndDepthInUserUnit = value;
        if (Parent != null)
        {
            selectedStartDepthString = Parent.FromSI(Parent.ToSI(selectedStartDepthInUserUnit, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling, false);
        }
        if (_depthMinMax != null && _depthMinMax.Count > 1)
        {
            _depthMinMax[1] = selectedStartDepthInUserUnit;
        }
        _ = Run();
        await Task.Yield();
    }

    private async Task OnProfileEndDepthChanged(double value)
    {
        selectedEndDepthInUserUnit = value;
        maximumStartDepthInUserUnit = value;
        if (Parent != null)
        {
            selectedEndDepthString = Parent.FromSI(Parent.ToSI(selectedEndDepthInUserUnit, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling, false);
        }
        if (_depthMinMax != null && _depthMinMax.Count > 1)
        {
            _depthMinMax[0] = selectedEndDepthInUserUnit;
        }
        _ = Run();
        await Task.Yield();
    }


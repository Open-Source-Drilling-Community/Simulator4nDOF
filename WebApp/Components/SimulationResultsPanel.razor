@using OSDC.UnitConversion.Conversion
@using OSDC.UnitConversion.Conversion.DrillingEngineering
@using Plotly.Blazor.LayoutLib
@using Plotly.Blazor.Traces.ScatterLib
@using MudBlazor
@inject IJSRuntime JS
@inherits LayoutComponentBase

@*<MudText Class="mt-4 mb-4" Typo="Typo.h6">Simulation results</MudText>*@
<MudLayout>

    @if (activeTab == 0 || activeTab == 2)
    {
        <MudPaper Elevation="2" Class="pa-2 mb-2" Outlined="true">
            <div class="d-flex align-center gap-4 flex-wrap">
                <MudGrid Class="d-flex align-center gap-4 flex-wrap">
                    <!-- Start Index -->
                    <MudItem xs = "3">
                        <MudText Typo="Typo.body1">Start time:</MudText>                           
                        <MudNumericField 
                            T="double"
                            Value="@timeStart"
                            ValueChanged="UpdateStartTimeIndex" 
                            HideSpinButtons="true"
                            />  
                    </MudItem>
                    <MudItem xs = "3">
                        <MudText Typo="Typo.body1">Start: @timeStart.ToString("F2") s</MudText>                    
                        <MudSlider T="double"
                               Value="@startIndex"
                               ValueChanged="OnStartIndexChanged"
                               Min="0"
                               Max="@maxIndex"
                               Step="1"
                               Immediate="true"
                               Color="Color.Primary"
                               />      
                    </MudItem>                                                 
                </MudGrid>
                <!-- End Index -->
                <MudGrid Class="d-flex align-center gap-4 flex-wrap">
                        <MudItem xs = "3">
                            <MudText Typo="Typo.body1">End time:</MudText>
                            <MudNumericField
                                T="double" 
                                Value="@timeEnd"
                                ValueChanged="UpdateFinalTimeIndex" 
                                HideSpinButtons="true"/>  
                        </MudItem>
                        <MudItem xs = "3">
                            <MudText Typo="Typo.body1">End: @timeEnd.ToString("F2") s</MudText>                            
                             <MudSlider T="double"
                                   Value="@endIndex"
                                   ValueChanged="OnEndIndexChanged"
                                   Min="@startIndex"
                                   Max="@maxIndex"
                                   Step="1"
                                   Immediate="true"
                                   Color="Color.Secondary"/>
                        </MudItem>
                </MudGrid>
            </div>
        </MudPaper>
    }


    @if (activeTab == 1)
    {
        <MudPaper Elevation="2" Class="pa-2 mb-2" Outlined="true">
            <MudGrid Class="pa-0 ma-0" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
                <MudItem xs="8" sm="2" md="2" lg="2" xl="2">
                    <MudSlider T="double"
                               Value="@selectedProfileIndex"
                               ValueChanged="OnProfileIndexChanged"
                               Min="0"
                               Max="@((Results?.Profiles?.Count ?? 1) - 1)"
                               Step="1"
                               Immediate="true"
                               Color="Color.Primary" />
                </MudItem>

                <MudItem xs="4" sm="2" md="2" lg="1" xl="1">
                    <MudText Typo="Typo.subtitle2" Class="ml-2">
                        Time (s): @selectedProfileTime.ToString("F2")
                    </MudText>
                </MudItem>
                <MudItem xs="8" sm="2" md="2" lg="2" xl="2">
                    <MudSlider T="double"
                               Value="@selectedStartDepthInUserUnit"
                               ValueChanged="OnProfileStartDepthChanged"
                               Min="@minimumDepthInUserUnit"
                               Max="@maximumStartDepthInUserUnit"
                               Step="@depthStep"
                               Immediate="true"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="4" sm="2" md="2" lg="1" xl="1">
                    <MudText Typo="Typo.subtitle2" Class="ml-2">
                        Start Depth ( @depthUnit ): @selectedStartDepthString
                    </MudText>
                </MudItem>
                <MudItem xs="8" sm="2" md="2" lg="2" xl="2">
                    <MudSlider T="double"
                               Value="@selectedEndDepthInUserUnit"
                               ValueChanged="OnProfileEndDepthChanged"
                               Min="@minimumEndDepthInUserUnit"
                               Max="@maximumDepthInUserUnit"
                               Step="@depthStepInUserUnit"
                               Immediate="true"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="4" sm="2" md="2" lg="1" xl="1">
                    <MudText Typo="Typo.subtitle2" Class="ml-2">
                        End Depth ( @depthUnit ): @selectedEndDepthString
                    </MudText>
                </MudItem>
                <MudItem xs="12" sm="12" md="12" lg="3" xl="3">
                    <MudStack Row AlignItems="_align" Spacing="1">
                        <MudTooltip Text="Start">
                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                           Color="Color.Success"
                                           Disabled="@(IsRunning && !IsPaused)"
                                           OnClick="Start" />
                        </MudTooltip>

                        <MudTooltip Text="Pause">
                            <MudIconButton Icon="@Icons.Material.Filled.Pause"
                                           Color="Color.Warning"
                                           Disabled="@( !IsRunning || IsPaused )"
                                           OnClick="Pause" />
                        </MudTooltip>

                        <MudTooltip Text="Stop">
                            <MudIconButton Icon="@Icons.Material.Filled.Stop"
                                           Color="Color.Error"
                                           Disabled="@( !IsRunning )"
                                           OnClick="Stop" />
                        </MudTooltip>
                        <MudTooltip Text="Record (only active when play is running)">
                            <MudIconButton Icon="@Icons.Material.Filled.FiberManualRecord"
                                           Color="@_recordButtonColor"
                                           OnClick="Record" />
                        </MudTooltip>
                        <MudTooltip Text="Save recorded video to file">
                            <MudIconButton Icon="@Icons.Material.Filled.SaveAs"
                                           Color="Color.Primary"
                                           Disabled="@( !_videoAvailable )"
                                           OnClick="SaveVideo" />
                        </MudTooltip>
                        <MudText Class="ms-3" Typo="Typo.caption">
                            State: @(IsRunning ? (IsPaused ? "Paused" : "Running") : "Stopped")
                        </MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }


    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" ActivePanelIndex="@activeTab" ActivePanelIndexChanged="OnTabChanged">

        <MudTabPanel Text="Time graphs">
            <MudGrid>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_depthLayout" @bind-Data="_depthTraces" @ref="_depthChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_rpmLayout" @bind-Data="_rpmTraces" @ref="_rpmChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_torqueLayout" @bind-Data="_torqueTraces" @ref="_torqueChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_velocityLayout" @bind-Data="_velocityTraces" @ref="_velocityChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_wobLayout" @bind-Data="_wobTraces" @ref="_wobChart" />
                </MudItem>
                <MudItem xs="6">
                    <PlotlyChart style="height: 25vh;" @bind-Config="_config" @bind-Layout="_ssiLayout" @bind-Data="_ssiTraces" @ref="_ssiChart" />
                </MudItem>

            </MudGrid>
        </MudTabPanel>
        <div id="gridToSnap">
            <MudTabPanel Text="Along String Depth graphs ">
                <MudGrid Class="pa-0 ma-0" Style="flex-wrap: nowrap; overflow-x: auto;" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_angularVelocityLayout" @bind-Data="_angularVelocityTraces" @ref="_angularVelocityChart" />
                    </MudItem>
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_axialVelocityLayout" @bind-Data="_axialVelocityTraces" @ref="_axialVelocityChart" />
                    </MudItem>
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_lateralDispLayout" @bind-Data="_lateralDispTraces" @ref="_lateralDispChart" />
                    </MudItem>
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_lateralDispALayout" @bind-Data="_lateralDispATraces" @ref="_lateralDispAChart" />
                    </MudItem>
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_bendingMomentLayout" @bind-Data="_bendingMomentTraces" @ref="_bendingMomentChart" />
                    </MudItem>
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_sideForceLayout" @bind-Data="_sideForceTraces" @ref="_sideForceChart" />
                    </MudItem>
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_torqueDLayout" @bind-Data="_torqueDTraces" @ref="_torqueDChart" />
                    </MudItem>
@*                     <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_tensionLayout" @bind-Data="_tensionTraces" @ref="_tensionChart" />
                    </MudItem>
 *@                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_wellBoreAnglesLayout" @bind-Data="_wellBoreAnglesTraces" @ref="_wellBoreAnglesChart" />
                    </MudItem>
                    <MudItem Style="flex: 0 0 10%;">
                        <PlotlyChart style="height: 50vh; min-height: 200px; width: 100%" @bind-Config="_config" @bind-Layout="_wellBoreCurvaturesLayout" @bind-Data="_wellBoreCurvaturesTraces" @ref="_wellBoreCurvaturesChart" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </div>

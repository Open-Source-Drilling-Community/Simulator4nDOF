    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = Run();
        }
        return base.OnAfterRenderAsync(firstRender);
    }


    private async Task AfterSetValueAsync()
    {
        // fake async behaviour
        await Task.Yield();
    }

    private Task Run()
    {
        return Task.Run(async () =>
        {
            if (Results?.Scalars?.Time?.Count > 0)
            {
                try
                {
                    var x = new List<object>();
                    var BitRPM = new List<object>();
                    var SurfaceRPM = new List<object>();
                    var BitDepth = new List<object>();
                    var HoleDepth = new List<object>();
                    var SurfaceTorque = new List<object>();
                    var BitTorque = new List<object>();
                    var WOB = new List<object>();
                    var SSI = new List<object>();
                    var TopOfStringAxialVelocity = new List<object>();
                    var BitAxialVelocity = new List<object>();
                    var y10 = new List<object>();

                    List<object> SensorAngularVelocity = new List<object>();
                    List<object> SensorWhirlVelocity = new List<object>();
                    List<object> SensorAxialVelocity = new List<object>();
                    List<object> SensorRadialVelocity = new List<object>();
                    List<object> SensorRadialAcc = new List<object>();
                    List<object> SensorTangentialAcc = new List<object>();
                    List<object> SensorAxialAcc = new List<object>();
                    List<object> SensorBendingMomentX = new List<object>();
                    List<object> SensorBendingMomentY = new List<object>();
                    List<object> SensorTension = new List<object>();
                    List<object> SensorTorque = new List<object>();

                    if (activeTab == 0)
                    {
                        for (int i = startIndex; i <= endIndex && i < Results.Scalars.Time.Count; i++)
                        {
                            x.Add(Results.Scalars.Time.ElementAt(i));
                            BitRPM.Add(Parent.FromSI(Results.Scalars.BitRPM.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling));
                            SurfaceRPM.Add(Parent.FromSI(Results.Scalars.SurfaceRPM.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling));
                            BitDepth.Add(Parent.FromSI(Results.Scalars.BitDepth.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling));
                            HoleDepth.Add(Parent.FromSI(Results.Scalars.HoleDepth.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling));
                            SurfaceTorque.Add(Parent.FromSI(Results.Scalars.SurfaceTorque.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling));
                            BitTorque.Add(Parent.FromSI(Results.Scalars.BitTorque.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling));
                            WOB.Add(Parent.FromSI(Results.Scalars.WOB.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.WeightOnBitDrilling));
                            TopOfStringAxialVelocity.Add(Parent.FromSI(Results.Scalars.TopOfStringAxialVelocity.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling));
                            BitAxialVelocity.Add(Parent.FromSI(Results.Scalars.BitAxialVelocity.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling));


                            SSI.Add(Results.Scalars.SSI.ElementAt(i));
                        }

                        ((Plotly.Blazor.Traces.Scatter)_bitRpmTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_bitRpmTrace).Y = BitRPM;
                        ((Plotly.Blazor.Traces.Scatter)_surfaceRpmTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_surfaceRpmTrace).Y = SurfaceRPM;

                        ((Plotly.Blazor.Traces.Scatter)_bitDepthTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_bitDepthTrace).Y = BitDepth;
                        ((Plotly.Blazor.Traces.Scatter)_holeDepthTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_holeDepthTrace).Y = HoleDepth;

                        ((Plotly.Blazor.Traces.Scatter)_surfaceTorqueTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_surfaceTorqueTrace).Y = SurfaceTorque;
                        ((Plotly.Blazor.Traces.Scatter)_bitTorqueTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_bitTorqueTrace).Y = BitTorque;

                        ((Plotly.Blazor.Traces.Scatter)_wobTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_wobTrace).Y = WOB;

                        ((Plotly.Blazor.Traces.Scatter)_ssiTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_ssiTrace).Y = SSI;

                        ((Plotly.Blazor.Traces.Scatter)_surfaceAxialVelocityTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_surfaceAxialVelocityTrace).Y = TopOfStringAxialVelocity;

                        ((Plotly.Blazor.Traces.Scatter)_bitAxialVelocityTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_bitAxialVelocityTrace).Y = BitAxialVelocity;



                        var time = x.Last();

                        _rpmLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.SurfaceRPM.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling),
                                time,
                                "Surface: " + Parent.FromSI(Results.Scalars.SurfaceRPM.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling, false),
                                -40, -30),
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.BitRPM.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling),
                                time,
                                "Bit: " + Parent.FromSI(Results.Scalars.BitRPM.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling, false),
                                -40, 30)
                        };

                        _torqueLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.SurfaceTorque.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling),
                                time,
                                "Surface: " + Parent.FromSI(Results.Scalars.SurfaceTorque.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling, false),
                                -40, -40),
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.BitTorque.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling),
                                time,
                                "Bit: " + Parent.FromSI(Results.Scalars.BitTorque.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling, false),
                                -40, 30)
                        };

                        _velocityLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.TopOfStringAxialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling),
                                time,
                                "Surface: " + Parent.FromSI(Results.Scalars.TopOfStringAxialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling, false),
                                -40, -40),
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.BitAxialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling),
                                time,
                                "Bit: " + Parent.FromSI(Results.Scalars.BitAxialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling, false),
                                -40, 30)
                        };

                        _depthLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.BitDepth.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling),
                                time,
                                "Bit: " + Parent.FromSI(Results.Scalars.BitDepth.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling, false),
                                -40, -40),
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.HoleDepth.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling),
                                time,
                                "Hole: " + Parent.FromSI(Results.Scalars.HoleDepth.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling, false),
                                -40, 30)
                        };

                        _wobLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(
                                Parent.FromSI(Results.Scalars.WOB.ElementAt(endIndex) , DrillingPhysicalQuantity.QuantityEnum.WeightOnBitDrilling),
                                time,
                                "WOB: " + Parent.FromSI(Results.Scalars.WOB.ElementAt(endIndex) , DrillingPhysicalQuantity.QuantityEnum.WeightOnBitDrilling, false),
                                -40, -30)
                        };

                        if (_rpmChart != null)
                            await InvokeAsync(async () => await _rpmChart.React());
                        if (_depthChart != null)
                            await InvokeAsync(async () => await _depthChart.React());
                        if (_torqueChart != null)
                            await InvokeAsync(async () => await _torqueChart.React());
                        if (_velocityChart != null)
                            await InvokeAsync(async () => await _velocityChart.React());
                        if (_wobChart != null)
                            await InvokeAsync(async () => await _wobChart.React());
                        if (_ssiChart != null)
                            await InvokeAsync(async () => await _ssiChart.React());
                    }
                    else if (activeTab == 1)
                    {
                        var depths = new List<object>();
                        var SideForce = new List<object>();
                        var SideForceSoftString = new List<object>();
                        if (selectedProfileIndex > Results.Profiles.Count)
                        {
                            selectedProfileIndex = Results.Profiles.Count - 1;
                        }
                        var profile = Results.Profiles.ElementAt(selectedProfileIndex);
                        selectedProfileTime = profile.Time;
                        double selectedStartDepth = Parent.ToSI(selectedStartDepthInUserUnit, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);
                        double selectedEndDepth = Parent.ToSI(selectedEndDepthInUserUnit, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);

                        for (int i = 0; i < profile.Depth.Count; i++)
                        {
                            double depth = profile.Depth.ElementAt(i);
                            if (depth >= selectedStartDepth && depth <= selectedEndDepth)
                            {
                                depths.Add(Parent.FromSI(depth, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling));
                                if (Math.Abs(profile.SideForce.ElementAt(i)) < 1e-2)
                                {
                                    SideForce.Add(null);
                                }
                                else
                                {
                                    SideForce.Add(Parent.FromSI(profile.SideForce.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling));
                                }
                                SideForceSoftString.Add(Parent.FromSI(profile.SideForceSoftString.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling));
                            }
                        }

                        ((Plotly.Blazor.Traces.Scatter)_sideForceTrace).X = SideForce;
                        ((Plotly.Blazor.Traces.Scatter)_sideForceTrace).Y = depths;
                        ((Plotly.Blazor.Traces.Scatter)_sideForceTraceSoftstring).X = SideForceSoftString;
                        ((Plotly.Blazor.Traces.Scatter)_sideForceTraceSoftstring).Y = depths;
                        if (_sideForceLayout.Annotations == null)
                        {
                            _sideForceLayout.Annotations = new List<Annotation>();
                        }
                        _sideForceLayout.Annotations.Clear();
                        if (SideForce.Count > 0 && SideForce.Last<object>() is double dlast && depths.Count > 0 && depths.Last<object>() is double ddepth)
                        {
                            string slast = Parent.FromSI(profile.SideForce.ElementAt(profile.SideForce.Count - 1), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling, false);
                            _sideForceLayout.Annotations.Add(CreateAnnotation(ddepth, dlast, "Bit: " + slast, 10, 30));
                        }
                        if (Simulation != null && Simulation.Config != null && Math.Abs(Simulation.Config.VirtualSensorPositionFromBit) > 1e-2 &&
                            profile.Depth != null && profile.Depth.Count > 0 &&
                            profile.SideForce != null && profile.SideForce.Count >= profile.Depth.Count)
                        {
                            double bitDepth = profile.Depth.Last<double>();
                            double sensorDepth = bitDepth - Simulation.Config.VirtualSensorPositionFromBit;
                            // search for index of sensor
                            int idx = 0;
                            foreach (var depth in profile.Depth)
                            {
                                if (depth - 1e-3 >= sensorDepth)
                                {
                                    break;
                                }
                                idx++;
                            }
                            if (idx < profile.SideForce.Count)
                            {
                                string ssensor = Parent.FromSI(profile.SideForce.ElementAt(idx), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling, false);
                                double dsf = Parent.FromSI(profile.SideForce.ElementAt(idx), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling);
                                double dsensor = Parent.FromSI(profile.Depth.ElementAt(idx), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);
                                _sideForceLayout.Annotations.Add(CreateAnnotation(dsensor, dsf, "Sensor: " + ssensor, 10, -30));
                            }
                        }
                        var PipeAngularVelocity = new List<object>();

                        for (int i = 0; i < profile.Depth.Count; i++)
                        {
                            double depth = profile.Depth.ElementAt(i);
                            if (depth >= selectedStartDepth && depth <= selectedEndDepth)
                            {
                                PipeAngularVelocity.Add(Parent.FromSI(profile.PipeAngularVelocity.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling));
                            }
                        }

                        ((Plotly.Blazor.Traces.Scatter)_pipeAngularVelocityTrace).X = PipeAngularVelocity;
                        ((Plotly.Blazor.Traces.Scatter)_pipeAngularVelocityTrace).Y = depths;

                        if (_angularVelocityLayout.Annotations == null)
                        {
                            _angularVelocityLayout.Annotations = new List<Annotation>();
                        }
                        _angularVelocityLayout.Annotations.Clear();
                        if (PipeAngularVelocity.Count > 0 && PipeAngularVelocity.Last<object>() is double drotvel && depths.Count > 0 && depths.Last<object>() is double ddrotvel)
                        {
                            string slast = Parent.FromSI(profile.PipeAngularVelocity.ElementAt(profile.PipeAngularVelocity.Count - 1), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling, false);
                            _angularVelocityLayout.Annotations.Add(CreateAnnotation(ddrotvel, drotvel, "Bit: " + slast, -40, 30));
                        }
                        if (Simulation != null && Simulation.Config != null && Math.Abs(Simulation.Config.VirtualSensorPositionFromBit) > 1e-2 &&
                            profile.Depth != null && profile.Depth.Count > 0 &&
                            profile.PipeAngularVelocity != null && profile.PipeAngularVelocity.Count >= profile.Depth.Count)
                        {
                            double bitDepth = profile.Depth.Last<double>();
                            double sensorDepth = bitDepth - Simulation.Config.VirtualSensorPositionFromBit;
                            // search for index of sensor
                            int idx = 0;
                            foreach (var depth in profile.Depth)
                            {
                                if (depth - 1e-3 >= sensorDepth)
                                {
                                    break;
                                }
                                idx++;
                            }
                            if (idx < profile.PipeAngularVelocity.Count)
                            {
                                string ssensor = Parent.FromSI(profile.PipeAngularVelocity.ElementAt(idx), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling, false);
                                double dsf = Parent.FromSI(profile.PipeAngularVelocity.ElementAt(idx), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling);
                                double dsensor = Parent.FromSI(profile.Depth.ElementAt(idx), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);
                                _angularVelocityLayout.Annotations.Add(CreateAnnotation(dsensor, dsf, "Sensor: " + ssensor, -40, -30));
                            }
                        }

                        var depthssleeves = new List<object>();
                        var SleevesAngularVelocity = new List<object>();


                        for (int i = 0; i < profile.SleevesDepth.Count; i++)
                        {
                            double depth = profile.SleevesDepth.ElementAt(i);
                            if (depth >= selectedStartDepth && depth <= selectedEndDepth)
                            {

                                depthssleeves.Add(Parent.FromSI(depth, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling));
                                SleevesAngularVelocity.Add(Parent.FromSI(profile.SleevesAngularVelocity.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling));
                            }
                        }

                        var RadialClearanceL = new List<object>();
                        var RadialClearanceR = new List<object>();
                        var LateralDisplacement = new List<object>();

                        for (int i = 0; i < profile.Depth.Count; i++)
                        {
                            double depth = profile.Depth.ElementAt(i);
                            if (depth >= selectedStartDepth && depth <= selectedEndDepth)
                            {
                                var clearance = Parent.FromSI(profile.RadialClearance.ElementAt(i), BasePhysicalQuantity.QuantityEnum.LengthSmall);

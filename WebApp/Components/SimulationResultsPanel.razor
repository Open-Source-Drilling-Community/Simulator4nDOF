    }

    private void CalculateMinMax()
    {
        if (Parent != null && Results != null && Results.Profiles != null && Results.Profiles.Count > 0)
        {
            _angularVelocityMinMax[0] = double.MaxValue;
            _angularVelocityMinMax[1] = double.MinValue;
            _bendingMomentMinMax[0] = double.MaxValue;
            _bendingMomentMinMax[1] = double.MinValue;
            _axialVelocityMinMax[0] = double.MaxValue;
            _axialVelocityMinMax[1] = double.MinValue;
            _lateralDispAMinMax[0] = double.MaxValue;
            _lateralDispAMinMax[1] = double.MinValue;
            _lateralDispMinMax[0] = double.MaxValue;
            _lateralDispMinMax[1] = double.MinValue;
            _sideForceMinMax[0] = double.MaxValue;
            _sideForceMinMax[1] = double.MinValue;
            _tensionMinMax[0] = double.MaxValue;
            _tensionMinMax[1] = double.MinValue;
            _torqueDMinMax[0] = double.MaxValue;
            _torqueDMinMax[1] = double.MinValue;
            _wellBoreAnglesMinMax[0] = double.MaxValue;
            _wellBoreAnglesMinMax[1] = double.MinValue;
            _wellBoreCurvaturesMinMax[0] = double.MaxValue;
            _wellBoreCurvaturesMinMax[1] = double.MinValue;
            minimumDepth = double.MaxValue;
            maximumDepth = double.MinValue;
            foreach (var prof in Results.Profiles)
            {
                if (prof != null)
                {
                    if (prof.Depth != null)
                    {
                        foreach (var x in prof.Depth)
                        {
                            if (x < minimumDepth)
                            {
                                minimumDepth = x;
                            }
                            if (x > maximumDepth)
                            {
                                maximumDepth = x;
                            }
                        }
                    }
                    if (prof.SleevesDepth != null)
                    {
                        foreach (var x in prof.SleevesDepth)
                        {
                            if (x < minimumDepth)
                            {
                                minimumDepth = x;
                            }
                            if (x > maximumDepth)
                            {
                                maximumDepth = x;
                            }
                        }
                    }
                    if (prof.PipeAngularVelocity != null)
                    {
                        foreach (var x in prof.PipeAngularVelocity)
                        {
                            if (x < (double)_angularVelocityMinMax[0])
                            {
                                _angularVelocityMinMax[0] = x;
                            }
                            if (x > (double)_angularVelocityMinMax[1])
                            {
                                _angularVelocityMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.BendingMoment != null)
                    {
                        foreach (var x in prof.BendingMoment)
                        {
                            if (x < (double)_bendingMomentMinMax[0])
                            {
                                _bendingMomentMinMax[0] = x;
                            }
                            if (x > (double)_bendingMomentMinMax[1])
                            {
                                _bendingMomentMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.AxialVelocityD != null)
                    {
                        foreach (var x in prof.AxialVelocityD)
                        {
                            if (x < (double)_axialVelocityMinMax[0])
                            {
                                _axialVelocityMinMax[0] = x;
                            }
                            if (x > (double)_axialVelocityMinMax[1])
                            {
                                _axialVelocityMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.LateralDisplacementAngle != null)
                    {
                        foreach (var x in prof.LateralDisplacementAngle)
                        {
                            if (x < (double)_lateralDispAMinMax[0])
                            {
                                _lateralDispAMinMax[0] = x;
                            }
                            if (x > (double)_lateralDispAMinMax[1])
                            {
                                _lateralDispAMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.LateralDisplacement != null)
                    {
                        foreach (var x in prof.LateralDisplacement)
                        {
                            if (x < (double)_lateralDispMinMax[0])
                            {
                                _lateralDispMinMax[0] = x;
                            }
                            if (x > (double)_lateralDispMinMax[1])
                            {
                                _lateralDispMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.RadialClearance != null)
                    {
                        foreach (var x in prof.RadialClearance)
                        {
                            if (-x < (double)_lateralDispMinMax[0])
                            {
                                _lateralDispMinMax[0] = x;
                            }
                            if (x > (double)_lateralDispMinMax[1])
                            {
                                _lateralDispMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.SideForce != null || prof.SideForceSoftString != null)
                    {
                        if (prof.SideForce != null)
                        {
                            foreach (var x in prof.SideForce)
                            {
                                if (x < (double)_sideForceMinMax[0])
                                {
                                    _sideForceMinMax[0] = x;
                                }
                                if (x > (double)_sideForceMinMax[1])
                                {
                                    _sideForceMinMax[1] = x;
                                }
                            }
                        }

                        if (prof.SideForceSoftString != null)
                        {
                            foreach (var x in prof.SideForceSoftString)
                            {
                                if (x < (double)_sideForceMinMax[0])
                                {
                                    _sideForceMinMax[0] = x;
                                }
                                if (x > (double)_sideForceMinMax[1])
                                {
                                    _sideForceMinMax[1] = x;
                                }
                            }
                        }
                    }
                    if (prof.Tension != null)
                    {
                        foreach (var x in prof.Tension)
                        {
                            if (x < (double)_tensionMinMax[0])
                            {
                                _tensionMinMax[0] = x;
                            }
                            if (x > (double)_tensionMinMax[1])
                            {
                                _tensionMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.Torque != null)
                    {
                        foreach (var x in prof.Torque)
                        {
                            if (x < (double)_torqueDMinMax[0])
                            {
                                _torqueDMinMax[0] = x;
                            }
                            if (x > (double)_torqueDMinMax[1])
                            {
                                _torqueDMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.Inclination != null)
                    {
                        foreach (var x in prof.Inclination)
                        {
                            if (x < (double)_wellBoreAnglesMinMax[0])
                            {
                                _wellBoreAnglesMinMax[0] = x;
                            }
                            if (x > (double)_wellBoreAnglesMinMax[1])
                            {
                                _wellBoreAnglesMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.Azimuth != null)
                    {
                        foreach (var x in prof.Azimuth)
                        {
                            if (x < (double)_wellBoreAnglesMinMax[0])
                            {
                                _wellBoreAnglesMinMax[0] = x;
                            }
                            if (x > (double)_wellBoreAnglesMinMax[1])
                            {
                                _wellBoreAnglesMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.Curvature != null)
                    {
                        foreach (var x in prof.Curvature)
                        {
                            if (x < (double)_wellBoreCurvaturesMinMax[0])
                            {
                                _wellBoreCurvaturesMinMax[0] = x;
                            }
                            if (x > (double)_wellBoreCurvaturesMinMax[1])
                            {
                                _wellBoreCurvaturesMinMax[1] = x;
                            }
                        }
                    }
                    if (prof.BuildUpRate != null)
                    {
                        foreach (var x in prof.BuildUpRate)
                        {
                            if (x < (double)_wellBoreCurvaturesMinMax[0])
                            {
                                _wellBoreCurvaturesMinMax[0] = x;
                            }
                            if (x > (double)_wellBoreCurvaturesMinMax[1])
                            {
                                _wellBoreCurvaturesMinMax[1] = x;
                            }
                        }
                    }
                }
            }
            selectedProfileIndex = Results?.Profiles?.Count > 0 ? Results.Profiles.Count - 1 : 0;
            if (minimumDepth == double.MaxValue)
            {
                minimumDepth = 0;
            }
            if (maximumDepth == double.MinValue)
            {
                maximumDepth = 0;
            }
            maximumStartDepthInUserUnit = maximumDepth;
            minimumEndDepthInUserUnit = minimumDepth;
            depthStep = (maximumDepth - minimumDepth) / 100;
            minimumDepthInUserUnit = Parent.FromSI(minimumDepth, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);
            maximumDepthInUserUnit = Parent.FromSI(maximumDepth, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);
            depthStepInUserUnit = Parent.FromSI(depthStep, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);
            maximumStartDepthInUserUnit = maximumDepthInUserUnit;
            minimumEndDepthInUserUnit = minimumDepthInUserUnit;
            selectedStartDepthInUserUnit = minimumDepthInUserUnit;
            selectedEndDepthInUserUnit = maximumDepthInUserUnit;
            selectedStartDepthString = Parent.FromSI(Parent.ToSI(selectedStartDepthInUserUnit, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling, false);
            selectedEndDepthString = Parent.FromSI(Parent.ToSI(selectedEndDepthInUserUnit, DrillingPhysicalQuantity.QuantityEnum.DepthDrilling), DrillingPhysicalQuantity.QuantityEnum.DepthDrilling, false);
            depthUnit = Parent.GetUnitLabel(DrillingPhysicalQuantity.QuantityEnum.DepthDrilling);
            if (_depthMinMax != null && _depthMinMax.Count > 1)
            {
                _depthMinMax[1] = minimumDepthInUserUnit;
                _depthMinMax[0] = maximumDepthInUserUnit;
            }
            if ((double)_angularVelocityMinMax[0] == double.MaxValue)
            {
                _angularVelocityMinMax[0] = null;
            }
            else
            {
                _angularVelocityMinMax[0] = Parent.FromSI((double)_angularVelocityMinMax[0], DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling);
            }
            if ((double)_angularVelocityMinMax[1] == double.MinValue)
            {
                _angularVelocityMinMax[1] = null;
            }
            else
            {
                _angularVelocityMinMax[1] = Parent.FromSI((double)_angularVelocityMinMax[1], DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling);
            }
            if ((double)_bendingMomentMinMax[0] == double.MaxValue)
            {
                _bendingMomentMinMax[0] = null;
            }
            else
            {
                _bendingMomentMinMax[0] = Parent.FromSI((double)_bendingMomentMinMax[0], DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling);
            }
            if ((double)_bendingMomentMinMax[1] == double.MinValue)
            {
                _bendingMomentMinMax[1] = null;
            }
            else
            {
                _bendingMomentMinMax[1] = Parent.FromSI((double)_bendingMomentMinMax[1], DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling);
            }
            if ((double)_axialVelocityMinMax[0] == double.MaxValue)
            {
                _axialVelocityMinMax[0] = null;
            }
            else
            {

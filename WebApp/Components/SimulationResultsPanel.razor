    private Color _recordButtonColor = Color.Info;
    private string _videoMime = "video/webm";
    private int _fps = 12;
    private int _width = 1024;
    private int _height = 576;
    private bool _videoAvailable = false;
    private record ComponentSize(double width, double height);

    private double selectedStartDepthInUserUnit = 0;
    private double selectedEndDepthInUserUnit = 0;
    private double minimumDepth = 0;
    private double minimumDepthInUserUnit = 0;
    private double maximumStartDepthInUserUnit = 0;
    private double minimumEndDepthInUserUnit = 0;
    private double maximumDepthInUserUnit = 0;
    private double maximumDepth = 0;
    private double depthStepInUserUnit = 1;
    private double depthStep = 1;

                        for (int i = startIndex; i <= endIndex && i < Results.Scalars.Time.Count; i++)
                        {
                            x.Add(Results.Scalars.Time.ElementAt(i));

                            SensorRadialAcc.Add(Results.Scalars.SensorRadialAcc.ElementAt(i) / 9.81);
                            SensorAngularVelocity.Add(Parent.FromSI(
                                Results.Scalars.SensorAngularVelocity.ElementAt(i),
                                DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling));

                            SensorWhirlVelocity.Add(Parent.FromSI(
                                Results.Scalars.SensorWhirlVelocity.ElementAt(i),
                                DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling));

                            SensorAxialVelocity.Add(Parent.FromSI(Results.Scalars.SensorAxialVelocity.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling));
                            SensorRadialVelocity.Add(Parent.FromSI(Results.Scalars.SensorRadialVelocity.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling));
                            SensorTangentialAcc.Add(Parent.FromSI(Results.Scalars.SensorTangentialAcc.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling));
                            SensorAxialAcc.Add(Parent.FromSI(Results.Scalars.SensorAxialAcc.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling));
                            SensorBendingMomentX.Add(Parent.FromSI(Results.Scalars.SensorBendingMomentX.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling));
                            SensorBendingMomentY.Add(Parent.FromSI(Results.Scalars.SensorBendingMomentY.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling));
                            SensorTension.Add(Parent.FromSI(Results.Scalars.SensorTension.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling));
                            SensorTorque.Add(Parent.FromSI(Results.Scalars.SensorTorque.ElementAt(i), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling));
                        }


                        ((Plotly.Blazor.Traces.Scatter)_sensorAngularVelocityTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorAngularVelocityTrace).Y = SensorAngularVelocity;

                        ((Plotly.Blazor.Traces.Scatter)_sensorWhirlVelocityTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorWhirlVelocityTrace).Y = SensorWhirlVelocity;

                        ((Plotly.Blazor.Traces.Scatter)_sensorAxialVelocityTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorAxialVelocityTrace).Y = SensorAxialVelocity;

                        ((Plotly.Blazor.Traces.Scatter)_sensorRadialVelocityTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorRadialVelocityTrace).Y = SensorRadialVelocity;

                        ((Plotly.Blazor.Traces.Scatter)_sensorRadialAccTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorRadialAccTrace).Y = SensorRadialAcc;

                        ((Plotly.Blazor.Traces.Scatter)_sensorTangentialAccTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorTangentialAccTrace).Y = SensorTangentialAcc;

                        ((Plotly.Blazor.Traces.Scatter)_sensorAxialAccTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorAxialAccTrace).Y = SensorAxialAcc;

                        ((Plotly.Blazor.Traces.Scatter)_sensorBendingMomentXTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorBendingMomentXTrace).Y = SensorBendingMomentX;

                        ((Plotly.Blazor.Traces.Scatter)_sensorBendingMomentYTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorBendingMomentYTrace).Y = SensorBendingMomentY;

                        ((Plotly.Blazor.Traces.Scatter)_sensorTensionTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorTensionTrace).Y = SensorTension;

                        ((Plotly.Blazor.Traces.Scatter)_sensorTorqueTrace).X = x;
                        ((Plotly.Blazor.Traces.Scatter)_sensorTorqueTrace).Y = SensorTorque;

                        var time = x.Last();

                        // Sensor Angular & Whirl Velocity
                        var latestSensorAngularVelocity = Parent.FromSI(
                            Results.Scalars.SensorAngularVelocity.ElementAt(endIndex),
                            DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling);
                        var latestSensorAngularVelocityString = Parent.FromSI(
                            Results.Scalars.SensorAngularVelocity.ElementAt(endIndex),
                            DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling, false);

                        var latestSensorWhirlVelocity = Parent.FromSI(
                            Results.Scalars.SensorWhirlVelocity.ElementAt(endIndex),
                            DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling);
                        var latestSensorWhirlVelocityString = Parent.FromSI(
                            Results.Scalars.SensorWhirlVelocity.ElementAt(endIndex),
                            DrillingPhysicalQuantity.QuantityEnum.AngularVelocityDrilling, false);

                        _sensorVelocityALayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestSensorAngularVelocity, time, "Angular: "+ latestSensorAngularVelocityString, -40, -40),
                            CreateAnnotation(latestSensorWhirlVelocity, time, "Whirl: " + latestSensorWhirlVelocityString, -40, -20)
                        };

                        // Sensor Axial & Radial Velocity
                        var latestSensorAxialVelocity = Parent.FromSI(Results.Scalars.SensorAxialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling);
                        var latestSensorAxialVelocityString = Parent.FromSI(Results.Scalars.SensorAxialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling, false);
                        var latestSensorRadialVelocity = Parent.FromSI(Results.Scalars.SensorRadialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling);
                        var latestSensorRadialVelocityString = Parent.FromSI(Results.Scalars.SensorRadialVelocity.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.RateOfPenetrationDrilling, false);

                        _sensorVelocityLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestSensorAxialVelocity, time, "Axial: " + latestSensorAxialVelocityString, -40, 20),
                            CreateAnnotation(latestSensorRadialVelocity, time, "Radial: " + latestSensorRadialVelocityString, -40, 40)
                        };

                        // Sensor Accelerations
                        var latestSensorRadialAcc = Parent.FromSI(Results.Scalars.SensorRadialAcc.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling);
                        var latestSensorRadialAccString = Parent.FromSI(Results.Scalars.SensorRadialAcc.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling, false);
                        _sensorRadialAccLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestSensorRadialAcc, time, latestSensorRadialAccString, -40, 20)
                        };

                        var latestSensorTangentialAcc = Parent.FromSI(Results.Scalars.SensorTangentialAcc.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling);
                        var latestSensorTangentialAccString = Parent.FromSI(Results.Scalars.SensorTangentialAcc.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling, false);
                        _sensorTangentialAccLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestSensorTangentialAcc, time, latestSensorTangentialAccString, -40, 20)
                        };

                        var latestSensorAxialAcc = Parent.FromSI(Results.Scalars.SensorAxialAcc.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling);
                        var latestSensorAxialAccString = Parent.FromSI(Results.Scalars.SensorAxialAcc.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.AccelerationDrilling, false);
                        _sensorAxialAccLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestSensorAxialAcc, time, latestSensorAxialAccString, -40, 20)
                        };

                        // Sensor Bending Moments
                        var latestBendingMomentX = Parent.FromSI(Results.Scalars.SensorBendingMomentX.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling);
                        var latestBendingMomentXString = Parent.FromSI(Results.Scalars.SensorBendingMomentX.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling, false);
                        var latestBendingMomentY = Parent.FromSI(Results.Scalars.SensorBendingMomentY.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling);
                        var latestBendingMomentYString = Parent.FromSI(Results.Scalars.SensorBendingMomentY.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling, false);

                        _sensorBendingMomentLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestBendingMomentX, time, "Mx: " + latestBendingMomentXString, -40, -20),
                            CreateAnnotation(latestBendingMomentY, time, "My: " + latestBendingMomentYString, -40, 20)
                        };

                        var latestTension = Parent.FromSI(Results.Scalars.SensorTension.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling);
                        var latestTensionString = Parent.FromSI(Results.Scalars.SensorTension.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.ForceDrilling, false);
                        _sensorTensionLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestTension, time, "T: " + latestTensionString, -40, -20),
                        };

                        var latestTorque = Parent.FromSI(Results.Scalars.SensorTorque.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling);
                        var latestTorqueString = Parent.FromSI(Results.Scalars.SensorTorque.ElementAt(endIndex), DrillingPhysicalQuantity.QuantityEnum.TorqueDrilling, false);
                        _sensorTorqueLayout.Annotations = new List<Annotation>
                        {
                            CreateAnnotation(latestTorque, time, "Trq: " + latestTorqueString, -40, -20),
                        };

                        if (_sensorVelocityAChart != null)
                            await InvokeAsync(async () => await _sensorVelocityAChart.React());
                        if (_sensorAxialAccChart != null)
                            await InvokeAsync(async () => await _sensorAxialAccChart.React());
                        if (_sensorBendingMomentChart != null)
                            await InvokeAsync(async () => await _sensorBendingMomentChart.React());
                        if (_sensorRadialAccChart != null)
                            await InvokeAsync(async () => await _sensorRadialAccChart.React());
                        if (_sensorTangentialAccChart != null)
                            await InvokeAsync(async () => await _sensorTangentialAccChart.React());
                        if (_sensorVelocityChart != null)
                            await InvokeAsync(async () => await _sensorVelocityChart.React());
                        if (_sensorTensionChart != null)
                            await InvokeAsync(async () => await _sensorTensionChart.React());
                        if (_sensorTorqueChart != null)
                            await InvokeAsync(async () => await _sensorTorqueChart.React());
                    }

                }
                catch (Exception e)
                {
                    Console.WriteLine(e.ToString());
                }

                InvokeAsync(() => StateHasChanged());
            }
        });
    }

}


    private string selectedStartDepthString = string.Empty;
    private string selectedEndDepthString = string.Empty;

    private int selectedProfileIndex;
    private double selectedProfileTime;

    private int activeTab = 0;

    private string value { get; set; } = "All";

    private int startIndex = 0;
    private int endIndex;
    private  List<double>  timeList => Results?.Scalars?.Time?.ToList();    
    private double timeStart = 0;
    private double timeEnd = 0;

    private int maxIndex => (Results?.Scalars?.Time?.Count ?? 1) - 1;
    private async Task UpdateStartTimeIndex(double val)
    {
        List<double> timeVectorDiff = new();
        foreach (double time in timeList)
        {
            timeVectorDiff.Add(Math.Abs(time-val));
        }
        startIndex = timeVectorDiff.IndexOf(timeVectorDiff.Min());
        timeStart = (double) timeList[startIndex];        
        await OnStartIndexChanged(startIndex);
    }

    private async Task UpdateFinalTimeIndex(double val)
    {
        List<double> timeVectorDiff = new();
        foreach (double time in timeList)
        {
            timeVectorDiff.Add(Math.Abs(time-val));
        }
        endIndex = timeVectorDiff.IndexOf(timeVectorDiff.Min());
        timeEnd = (double) timeList[endIndex];        
        await OnEndIndexChanged(endIndex);
    }

    private async Task StartVideo()
    {
        // Ensure grid has a stable layout at the size you want to export
        // If your grid is responsive, you can read its size from JS instead.
        _videoAvailable = false;
        var s = await JS.InvokeAsync<ComponentSize>("sizeUtil.getSizeById", "gridToSnap");
        if (s != null)
        {
            _width = (int)s.width;
            _height = (int)s.height;
        }

        await JS.InvokeAsync<bool>("videoSnap.start", _width, _height, _fps);
        lock (_lock)
        {
            _recording = true;
        }
    }

    private async Task FinishVideo()
    {
        bool recording = false;
        lock (_lock)
        {
            recording = _recording;
        }
        if (!recording) return;
        _videoAvailable = await JS.InvokeAsync<bool>("videoSnap.finish");
        lock (_lock)
        {
            _recording = false;
        }
        StateHasChanged();
    }

    private async Task SaveVideo()
    {
        if (_videoAvailable)
        {
            var name = $"Simulator4nDOF-{DateTime.Now:yyyyMMdd-HHmmss}.webm";
            await JS.InvokeVoidAsync("videoSnap.download", name);
            await JS.InvokeVoidAsync("videoSnap.revoke");
            _videoAvailable = false;
        }
    }

    private async Task Record()
    {

        _recording = !_recording;
        bool recording = false;
        lock (_lock)
        {
            recording = _recording;
        }
        if (recording)
        {
            _recordButtonColor = Color.Error;
        }
        else
        {
            _recordButtonColor = Color.Info;
        }
        await Task.Yield();
    }

    private async Task Start()
    {
        // If coming from Stopped, ensure we’re at t=0
        if (!IsRunning)
        {
            _ticks = 0;
            bool recording = false;
            lock (_lock)
            {
                recording = _recording;
            }
            if (recording)
            {
                // Start video recording
                await StartVideo();
            }
        }
        if (IsPaused)
        {
            // Resume from Paused
            IsPaused = false;
            _worker?.Resume();
            return;
        }
        IsRunning = true;
        IsPaused = false;
        _worker?.Start();
    }

    private void Pause()
    {
        if (!IsRunning) return;
        IsPaused = true;
        _worker?.Pause();
    }

    private async Task Stop()
    {
        _worker?.Stop();
        bool recording = false;
        lock (_lock)
        {
            recording = _recording;
        }
        if (recording)
        {
            await FinishVideo();
        }
        if (!IsRunning) return;
        IsRunning = false;
        IsPaused = false;
        _ticks = 0;
    }

    public void Dispose()
    {
        _worker?.Dispose();
    }
    private async Task TakeSnapShot(CancellationToken ct)
    {
        // increment once and capture the value
        var tick = Interlocked.Increment(ref _ticks);

        // Hop to the Blazor renderer thread for all UI+JS work
        await InvokeAsync(async () =>
        {
            if (ct.IsCancellationRequested)
            {
                return;
            }

            // if this mutates UI state, keep it on the UI thread
            await OnProfileIndexChanged(tick);

            // give the browser a tick if the layout just changed
            await Task.Yield();
            bool recording = false;
            lock (_lock)
            {
                recording = _recording;
            }
            if (recording)
            {
                // capture + addFrame — both must be on the UI thread
                await JS.InvokeVoidAsync(
                  "captureAndAddFrame",
                  "gridToSnap",
                  new { width = _width, height = _height, scale = 1, backgroundColor = "#ffffff" }
                );
            }

            if (tick >= (Results?.Profiles?.Count ?? 1) - 1)
            {
                // Stop likely calls JS too—keep it on UI thread
                await Stop();
            }
        });
    }

    private async Task OnStartIndexChanged(double value)
    {
        startIndex = Math.Min((int)value, endIndex);
        await Refresh();
    }

    private async Task OnEndIndexChanged(double value)
    {
        endIndex = Math.Max((int)value, startIndex);
        await Refresh();
    }


